---
import type { Product } from '../data/products';

interface Props {
  product: Product;
  index?: number;
}

const { product, index = 0 } = Astro.props;
---

<article class="product-card" id={`product-${product.id}`} style={`--card-accent:${product.accent}; --card-delay:${index * 80}ms;`}>
  <div class="product-card__media">
    <img
      src={product.image}
      alt={`${product.name} powder sample`}
      width="800"
      height="560"
      loading={index < 2 ? 'eager' : 'lazy'}
      decoding="async"
    />
  </div>

  <div class="product-card__body">
    <div class="product-card__head">
      <div>
        <p class="product-card__code">{product.code}</p>
        <h3>{product.name}</h3>
      </div>
      <p class="product-card__price">{product.priceLabel}</p>
    </div>

    <p class="product-card__description">{product.description}</p>

    <dl class="product-card__specs">
      <div>
        <dt>Particle size</dt>
        <dd>{product.particleSize}</dd>
      </div>
      <div>
        <dt>Lead time</dt>
        <dd>{product.leadTime}</dd>
      </div>
    </dl>

    <ul class="product-card__chips" aria-label={`${product.name} applications`}>
      {product.applications.map((application) => <li>{application}</li>)}
    </ul>
  </div>
</article>

<style>
  .product-card {
    position: relative;
    display: grid;
    gap: 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.65rem;
    overflow: clip;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02)),
      rgba(10, 14, 18, 0.92);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 28px 80px rgba(0, 0, 0, 0.28);
    animation: card-rise 0.75s cubic-bezier(0.2, 1, 0.22, 1) both;
    animation-delay: var(--card-delay);
  }

  .product-card::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--card-accent) 28%, transparent), transparent 42%),
      linear-gradient(180deg, transparent 55%, rgba(255, 255, 255, 0.02));
    opacity: 0.95;
  }

  .product-card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--card-accent) 45%, rgba(255, 255, 255, 0.14));
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.08) inset,
      0 34px 90px rgba(0, 0, 0, 0.34);
  }

  .product-card__media {
    position: relative;
    aspect-ratio: 10 / 7;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: #10141a;
  }

  .product-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 280ms ease;
  }

  .product-card:hover .product-card__media img {
    transform: scale(1.03);
  }

  .product-card__body {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1rem;
    padding: 0 1.35rem 1.35rem;
  }

  .product-card__head {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr auto;
    align-items: start;
  }

  .product-card__head h3 {
    margin: 0.2rem 0 0;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
  }

  .product-card__code {
    margin: 0;
    color: var(--card-accent);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .product-card__price {
    margin: 0;
    padding: 0.65rem 0.8rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    color: var(--text);
    font-weight: 600;
    white-space: nowrap;
  }

  .product-card__description {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .product-card__specs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    margin: 0;
  }

  .product-card__specs div {
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .product-card__specs dt {
    margin: 0 0 0.4rem;
    color: var(--muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .product-card__specs dd {
    margin: 0;
    color: var(--text);
    font-size: 1rem;
    font-weight: 600;
  }

  .product-card__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .product-card__chips li {
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--muted);
    border: 1px solid rgba(255, 255, 255, 0.05);
    font-size: 0.82rem;
  }

  @keyframes card-rise {
    from {
      opacity: 0;
      transform: translateY(24px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 720px) {
    .product-card__head {
      grid-template-columns: 1fr;
    }

    .product-card__price {
      justify-self: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-card,
    .product-card__media img {
      animation: none;
      transition: none;
    }
  }
</style>
