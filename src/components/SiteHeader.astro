---
import { siteInfo } from '../data/site';

interface Props {
  pathname: string;
  productsHref?: string;
  contactHref?: string;
}

const {
  pathname,
  productsHref = '/#products',
  contactHref = '/#contact',
} = Astro.props;

const homePage = pathname === '/';
const blogPage = pathname.startsWith('/blog/') || pathname.startsWith('/posts/');

const links = [
  {
    href: productsHref,
    label: 'Products',
    active: homePage,
  },
  {
    href: '/blog/',
    label: 'Blog',
    active: blogPage,
  },
  {
    href: '/FAQ/',
    label: 'FAQ',
    active: pathname === '/FAQ/',
  },
  {
    href: pathname === '/' ? contactHref : '/Contact/',
    label: 'Contact',
    active: pathname === '/Contact/',
  },
];
---

<header class="site-header" data-site-header data-open="false">
  <div class="site-header__inner page-shell">
    {
      homePage ? (
        <h1 class="brand-heading">
          <a class="brand" href="/" aria-label={`${siteInfo.brand} home`}>
            <span>{siteInfo.brand}</span>
          </a>
        </h1>
      ) : (
        <a class="brand" href="/" aria-label={`${siteInfo.brand} home`}>
          <span>{siteInfo.brand}</span>
        </a>
      )
    }

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-drawer" data-nav-toggle>
      <span class="nav-toggle__lines" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
      <span>Menu</span>
    </button>

    <nav class="site-nav site-nav--desktop" aria-label="Primary">
      {
        links.map((link) => (
          <a href={link.href} aria-current={link.active ? 'page' : undefined} data-active={link.active ? 'true' : 'false'}>
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>

  <button class="drawer-backdrop" type="button" aria-label="Close menu" tabindex="-1" data-nav-close></button>

  <aside class="site-drawer" id="mobile-drawer" aria-label="Mobile navigation" aria-hidden="true" data-drawer>
    <div class="site-drawer__header">
      <p>Navigation</p>
      <button class="site-drawer__close" type="button" aria-label="Close menu" data-nav-close>
        <span></span>
        <span></span>
      </button>
    </div>

    <nav class="site-drawer__nav" aria-label="Mobile primary">
      {
        links.map((link) => (
          <a
            href={link.href}
            aria-current={link.active ? 'page' : undefined}
            data-active={link.active ? 'true' : 'false'}
            data-drawer-link
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </aside>
</header>

<script is:inline>
  const header = document.querySelector('[data-site-header]');

  if (header instanceof HTMLElement) {
    const toggle = header.querySelector('[data-nav-toggle]');
    const drawer = header.querySelector('[data-drawer]');
    const closeButtons = header.querySelectorAll('[data-nav-close], [data-drawer-link]');

    const sync = (open) => {
      header.dataset.open = String(open);
      if (toggle instanceof HTMLButtonElement) {
        toggle.setAttribute('aria-expanded', String(open));
      }
      if (drawer instanceof HTMLElement) {
        drawer.setAttribute('aria-hidden', String(!open));
      }
    };

    const closeDrawer = () => sync(false);

    if (toggle instanceof HTMLButtonElement) {
      toggle.addEventListener('click', () => {
        sync(header.dataset.open !== 'true');
      });
    }

    closeButtons.forEach((node) => {
      node.addEventListener('click', closeDrawer);
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeDrawer();
      }
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth > 760) {
        closeDrawer();
      }
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    width: 100%;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(8, 11, 14, 0.94), rgba(8, 11, 14, 0.84)),
      rgba(8, 11, 14, 0.9);
    backdrop-filter: blur(18px);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 1.4rem;
    padding-block: 1rem 0.9rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    padding-inline-start: 0.12rem;
    color: var(--text);
    font-size: clamp(1.38rem, 1.12rem + 0.7vw, 1.82rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    white-space: nowrap;
  }

  .brand-heading {
    margin: 0;
    font-size: inherit;
    line-height: inherit;
  }

  .site-nav {
    display: grid;
    grid-auto-flow: column;
    align-items: center;
    justify-self: end;
    gap: 0.4rem;
    padding: 0.35rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      rgba(11, 15, 19, 0.78);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.05) inset,
      0 16px 36px rgba(0, 0, 0, 0.18);
  }

  .site-nav a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.85rem;
      padding-inline: 1rem;
    border-radius: 999px;
    color: #aab7c4;
    font-size: 0.98rem;
    font-weight: 650;
    letter-spacing: -0.01em;
    transition:
      color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .site-nav a:hover,
  .site-nav a[data-active='true'] {
    color: var(--text);
    background: rgba(255, 255, 255, 0.07);
  }

  .site-nav a:hover {
    transform: translateY(-1px);
  }

  .nav-toggle,
  .drawer-backdrop,
  .site-drawer {
    display: none;
  }

  @media (max-width: 760px) {
    .site-header__inner {
      grid-template-columns: 1fr auto;
      gap: 0.9rem;
      padding-block: 0.95rem 0.85rem;
    }

    .brand {
      font-size: clamp(1.18rem, 5vw, 1.4rem);
    }

    .site-nav--desktop {
      display: none;
    }

    .nav-toggle {
      display: inline-flex;
      align-items: center;
      gap: 0.65rem;
      justify-content: center;
      min-height: 2.9rem;
      padding: 0.7rem 0.95rem;
      color: var(--text);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 999px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02)),
        rgba(11, 15, 19, 0.82);
      box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.05) inset,
        0 12px 26px rgba(0, 0, 0, 0.14);
    }

    .nav-toggle span:last-child {
      font-size: 0.94rem;
      font-weight: 650;
      letter-spacing: -0.01em;
    }

    .nav-toggle__lines {
      display: grid;
      gap: 0.22rem;
    }

    .nav-toggle__lines span {
      display: block;
      width: 1rem;
      height: 2px;
      border-radius: 999px;
      background: currentColor;
      transition: transform 180ms ease, opacity 180ms ease;
    }

    .drawer-backdrop {
      position: fixed;
      inset: 0;
      z-index: 48;
      display: block;
      border: 0;
      padding: 0;
      background: rgba(3, 6, 8, 0.48);
      opacity: 0;
      pointer-events: none;
      transition: opacity 220ms ease;
    }

    .site-drawer {
      position: fixed;
      top: 0;
      right: 0;
      z-index: 49;
      display: grid;
      align-content: start;
      gap: 0.9rem;
      width: min(78vw, 320px);
      height: 100dvh;
      padding: 1rem 0.95rem;
      border-left: 1px solid rgba(255, 255, 255, 0.08);
      background:
        linear-gradient(180deg, rgba(16, 22, 28, 0.98), rgba(9, 13, 17, 0.98)),
        rgba(8, 11, 14, 0.98);
      box-shadow: none;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translate3d(calc(100% + 1rem), 0, 0);
      transition:
        transform 240ms cubic-bezier(0.2, 1, 0.22, 1),
        opacity 180ms ease,
        visibility 0ms linear 240ms;
    }

    .site-drawer__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding-block: 0.08rem 0.25rem;
    }

    .site-drawer__header p {
      margin: 0;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .site-drawer__close {
      position: relative;
      width: 2.85rem;
      height: 2.85rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.03);
    }

    .site-drawer__close span {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 1rem;
      height: 2px;
      background: var(--text);
      border-radius: 999px;
    }

    .site-drawer__close span:first-child {
      transform: translate(-50%, -50%) rotate(45deg);
    }

    .site-drawer__close span:last-child {
      transform: translate(-50%, -50%) rotate(-45deg);
    }

    .site-drawer__nav {
      display: grid;
      align-content: start;
      gap: 0.5rem;
    }

    .site-drawer__nav a {
      display: flex;
      align-items: center;
      min-height: 3.1rem;
      padding: 0.78rem 0.95rem;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 0.95rem;
      color: #b9c5d1;
      background: rgba(255, 255, 255, 0.03);
      font-size: 0.98rem;
      font-weight: 650;
      letter-spacing: -0.02em;
    }

    .site-drawer__nav a[data-active='true'] {
      color: var(--text);
      border-color: rgba(143, 228, 217, 0.28);
      background: rgba(143, 228, 217, 0.08);
    }

    .site-header[data-open='true'] .drawer-backdrop {
      opacity: 1;
      pointer-events: auto;
    }

    .site-header[data-open='true'] .site-drawer {
      box-shadow: -24px 0 70px rgba(0, 0, 0, 0.35);
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translate3d(0, 0, 0);
      transition:
        transform 240ms cubic-bezier(0.2, 1, 0.22, 1),
        opacity 180ms ease,
        visibility 0ms linear 0ms;
    }

    .site-header[data-open='true'] .nav-toggle__lines span:nth-child(1) {
      transform: translateY(4px) rotate(45deg);
    }

    .site-header[data-open='true'] .nav-toggle__lines span:nth-child(2) {
      opacity: 0;
    }

    .site-header[data-open='true'] .nav-toggle__lines span:nth-child(3) {
      transform: translateY(-4px) rotate(-45deg);
    }
  }

  @media (max-width: 420px) {
    .brand {
      font-size: 1.08rem;
    }

    .nav-toggle {
      min-height: 2.75rem;
      padding-inline: 0.82rem;
    }

    .nav-toggle span:last-child {
      font-size: 0.88rem;
    }

    .site-drawer {
      width: min(80vw, 300px);
      padding: 0.95rem 0.9rem;
    }

    .site-drawer__nav a {
      min-height: 2.95rem;
      padding: 0.72rem 0.9rem;
      font-size: 0.95rem;
    }
  }
</style>
