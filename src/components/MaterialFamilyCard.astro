---
import type { MaterialFamily } from '../data/materialFamilies';

interface Props {
  family: MaterialFamily;
  productCount?: number;
  articleCount?: number;
}

const { family, productCount = family.relatedProductIds.length, articleCount = family.relatedArticleSlugs.length } = Astro.props;
const productLabel = `${productCount} product${productCount === 1 ? '' : 's'}`;
const articleLabel = `${articleCount} article${articleCount === 1 ? '' : 's'}`;
---

<a class="family-card" href={`/materials/${family.slug}/`}>
  <p class="family-card__eyebrow">{family.label}</p>
  <h3>{family.title}</h3>
  <p>{family.summary}</p>
  <div class="family-card__meta">
    <span>{productLabel}</span>
    <span>{articleLabel}</span>
  </div>
</a>

<style>
  .family-card {
    display: grid;
    gap: 0.9rem;
    padding: 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.35rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      rgba(10, 14, 18, 0.88);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease;
  }

  .family-card:hover {
    transform: translateY(-2px);
    border-color: rgba(143, 228, 217, 0.24);
  }

  .family-card__eyebrow {
    margin: 0;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .family-card h3 {
    margin: 0;
    font-size: 1.22rem;
    line-height: 1.15;
    letter-spacing: -0.04em;
  }

  .family-card p:last-of-type {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .family-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .family-card__meta span {
    padding: 0.42rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--muted);
    border: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 0.82rem;
  }
</style>
