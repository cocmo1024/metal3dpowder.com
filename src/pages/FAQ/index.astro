---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { faqs } from '../../data/faqs';
import { siteInfo } from '../../data/site';

const title = 'FAQ | Metal 3D Powder';
const description =
  'Metal additive manufacturing FAQ covering powder basics, quality control, quotation details, storage, and export-oriented buying questions.';

const groupedFaqs = Object.entries(
  faqs.reduce<Record<string, typeof faqs>>((acc, item) => {
    acc[item.category] ??= [];
    acc[item.category].push(item);
    return acc;
  }, {}),
);

const siteUrl = Astro.site ?? new URL('https://metal3dpowder.com');
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer.join(' '),
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: siteUrl.toString(),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'FAQ',
        item: new URL('/FAQ/', siteUrl).toString(),
      },
    ],
  },
];
---

<BaseLayout title={title} description={description} canonical="/FAQ/" schema={schema}>
  <SiteHeader pathname={Astro.url.pathname} />

  <main class="page-shell content-page faq-page">
    <section class="page-intro">
      <p class="eyebrow">FAQ</p>
      <h1>Technical and commercial questions buyers usually ask first.</h1>
      <p>
        This FAQ focuses on the powder, quality, quotation, and delivery questions that usually matter first to
        engineering teams and overseas buyers.
      </p>
    </section>

    <section class="copy-grid">
      <div class="surface-card surface-card--padded rich-copy">
        <h2>Before you request a quote</h2>
        <p>Include alloy grade, PSD window, target AM process, quantity, and destination country.</p>
        <p>
          If qualification matters, also send printer model, oxygen limits, preferred package size, and the documents
          you need with shipment.
        </p>
      </div>

      <div class="surface-card surface-card--padded rich-copy">
        <h2>Official contact</h2>
        <p>
          Email: <a class="inline-link" href={`mailto:${siteInfo.email}`}>{siteInfo.email}</a>
        </p>
        <p>{siteInfo.contactNote}</p>
      </div>
    </section>

    {
      groupedFaqs.map(([category, items]) => (
        <section class="surface-card surface-card--padded faq-section">
          <div class="faq-section__head">
            <p class="eyebrow">{category}</p>
            <h2>{category}</h2>
          </div>

          <div class="faq-list">
            {items.map((item) => (
              <details>
                <summary>{item.question}</summary>
                <div class="faq-answer">
                  {item.answer.map((paragraph) => <p>{paragraph}</p>)}
                </div>
              </details>
            ))}
          </div>
        </section>
      ))
    }
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .faq-page {
    gap: 1.5rem;
    padding-block: 2rem 4rem;
  }

  .faq-page .page-intro {
    gap: 0.65rem;
    max-width: 50rem;
  }

  .faq-page .page-intro h1 {
    font-size: clamp(1.74rem, 2.85vw, 2.24rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .faq-page .page-intro p {
    max-width: 44rem;
    font-size: 1rem;
    line-height: 1.72;
  }

  .faq-page .copy-grid {
    gap: 1rem;
  }

  .faq-page .rich-copy {
    gap: 0.75rem;
  }

  .faq-page .rich-copy h2 {
    margin: 0;
    font-size: 1.06rem;
    line-height: 1.24;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  .faq-section {
    display: grid;
    gap: 1rem;
  }

  .faq-section__head {
    display: grid;
    gap: 0.45rem;
  }

  .faq-section__head h2 {
    margin: 0;
    font-size: clamp(1.16rem, 2vw, 1.44rem);
    line-height: 1.18;
    letter-spacing: -0.025em;
    font-weight: 720;
  }

  .faq-list {
    display: grid;
    gap: 0.8rem;
  }

  .faq-list details {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.15rem;
    background: rgba(255, 255, 255, 0.03);
    overflow: hidden;
  }

  .faq-list summary {
    padding: 0.95rem 1.05rem;
    cursor: pointer;
    list-style: none;
    font-size: 0.94rem;
    line-height: 1.45;
    font-weight: 680;
    letter-spacing: -0.015em;
  }

  .faq-list summary::-webkit-details-marker {
    display: none;
  }

  .faq-answer {
    display: grid;
    gap: 0.75rem;
    padding: 0 1.1rem 1.1rem;
  }

  .faq-answer p {
    margin: 0;
    color: #d3dce6;
    line-height: 1.78;
    font-size: 0.98rem;
  }

  @media (max-width: 720px) {
    .faq-page {
      gap: 1.35rem;
      padding-block: 1.85rem 3.2rem;
    }

    .faq-page .page-intro h1 {
      font-size: clamp(1.46rem, 6.3vw, 1.92rem);
      line-height: 1.14;
      letter-spacing: -0.024em;
    }

    .faq-page .rich-copy h2,
    .faq-section__head h2 {
      font-size: 1.01rem;
    }
  }
</style>
