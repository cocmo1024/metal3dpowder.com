---
import { getCollection } from 'astro:content';
import ContentHub from '../../components/ContentHub.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBlogPostPath, sortBlogPosts, type BlogPost } from '../../data/blog';
import { processHubs, type HubDefinition } from '../../data/contentHubs';
import { buildBreadcrumbSchema, buildCollectionPageSchema } from '../../data/seo';
import { siteInfo } from '../../data/site';

interface Props {
  hub: HubDefinition;
}

export function getStaticPaths() {
  return processHubs.map((hub) => ({
    params: { slug: hub.slug },
    props: { hub },
  }));
}

const { hub } = Astro.props;
const allPosts = sortBlogPosts(await getCollection('blog'));
const postMap = new Map(allPosts.map((post) => [post.id, post]));
const posts = hub.postIds.map((id) => postMap.get(id)).filter((post): post is BlogPost => Boolean(post));
const canonical = `/processes/${hub.slug}/`;
const siteUrl = Astro.site ?? new URL('https://metal3dpowder.com');
const schema = [
  buildCollectionPageSchema({
    site: siteUrl,
    path: canonical,
    name: `${hub.title} guides`,
    description: hub.description,
    items: posts.map((post) => ({ name: post.data.title, path: getBlogPostPath(post) })),
  }),
  buildBreadcrumbSchema(siteUrl, [
    { name: 'Home', path: '/' },
    { name: 'Processes', path: '/processes/' },
    { name: hub.title },
  ]),
];
---

<BaseLayout title={`${hub.title} Guides | ${siteInfo.brand}`} description={hub.description} canonical={canonical} schema={schema}>
  <SiteHeader pathname={Astro.url.pathname} />
  <ContentHub
    eyebrow="Process center"
    title={`${hub.title} Guides`}
    description={hub.description}
    posts={posts}
    postsTitle="Articles in this process center"
  />
  <SiteFooter />
</BaseLayout>

