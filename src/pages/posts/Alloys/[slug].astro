---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import {
  blogAuthorName,
  estimateReadingMinutes,
  getAdjacentBlogPosts,
  getBlogPostPath,
  getTagPath,
  sortBlogPosts,
} from '../../../data/blog';
import { siteInfo } from '../../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = sortBlogPosts(await getCollection('blog'));
const { previousPost, nextPost } = getAdjacentBlogPosts(allPosts, post.id);
const readingMinutes = estimateReadingMinutes(post.body ?? '');
const formatter = new Intl.DateTimeFormat('en-US', { dateStyle: 'long' });

const canonical = getBlogPostPath(post);
const siteUrl = Astro.site ?? new URL('https://metal3dpowder.com');
const publishedIso = post.data.pubDate.toISOString();
const modifiedIso = (post.data.updatedDate ?? post.data.pubDate).toISOString();

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    articleSection: post.data.category,
    keywords: post.data.tags.join(', '),
    datePublished: publishedIso,
    dateModified: modifiedIso,
    mainEntityOfPage: new URL(canonical, siteUrl).toString(),
    author: {
      '@type': 'Organization',
      name: blogAuthorName,
    },
    publisher: {
      '@type': 'Organization',
      name: siteInfo.brand,
      logo: {
        '@type': 'ImageObject',
        url: new URL('/og-image.svg', siteUrl).toString(),
      },
    },
  },
];
---

<BaseLayout
  title={`${post.data.title} | ${siteInfo.brand}`}
  description={post.data.description}
  canonical={canonical}
  ogType="article"
  extraMeta={[
    { property: 'article:published_time', content: publishedIso },
    { property: 'article:modified_time', content: modifiedIso },
    { property: 'article:section', content: post.data.category },
    { name: 'author', content: blogAuthorName },
  ]}
  schema={schema}
>
  <SiteHeader pathname={Astro.url.pathname} />

  <main class="page-shell article-page">
    <article class="article">
      <header class="article-header">
        <h1>{post.data.title}</h1>

        <div class="article-meta">
          <span>{post.data.category}</span>
          <span>{blogAuthorName}</span>
          <span>{formatter.format(post.data.pubDate)}</span>
          <span>{readingMinutes} min read</span>
        </div>
      </header>

      <section class="article-summary" aria-labelledby="article-summary-title">
        <h2 id="article-summary-title">Summary</h2>
        <p>{post.data.description}</p>
      </section>

      <section class="article-content">
        <Content />
      </section>

      <section class="article-tags" aria-labelledby="article-tags-title">
        <h2 id="article-tags-title">Tags</h2>
        <div class="article-tags__list">
          {post.data.tags.map((tag) => (
            <a href={getTagPath(tag)}>{tag}</a>
          ))}
        </div>
      </section>

      <nav class="article-pagination" aria-label="Article pagination">
        {previousPost ? (
          <a class="article-pagination__link" href={getBlogPostPath(previousPost)}>
            <span>Previous article</span>
            <strong>{previousPost.data.title}</strong>
          </a>
        ) : null}

        {nextPost ? (
          <a class="article-pagination__link" href={getBlogPostPath(nextPost)}>
            <span>Next article</span>
            <strong>{nextPost.data.title}</strong>
          </a>
        ) : null}
      </nav>
    </article>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .article-page {
    padding-block: 2rem 4rem;
  }

  .article {
    display: grid;
    gap: 1.5rem;
    max-width: 840px;
    margin-inline: auto;
  }

  .article-header,
  .article-summary,
  .article-tags,
  .article-pagination {
    display: grid;
    gap: 0.8rem;
  }

  .article-header h1,
  .article-summary h2,
  .article-tags h2,
  .article-content :global(h2),
  .article-content :global(h3) {
    margin: 0;
  }

  .article-header h1 {
    max-width: 17ch;
    font-size: clamp(1.9rem, 3.3vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    font-weight: 730;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1rem;
    color: var(--muted);
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.11em;
  }

  .article-summary {
    padding: 1rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .article-summary h2,
  .article-tags h2 {
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-summary p,
  .article-content :global(p),
  .article-content :global(li) {
    margin: 0;
    color: #d3dce6;
    line-height: 1.8;
    font-size: 0.98rem;
  }

  .article-content {
    display: grid;
    gap: 0;
  }

  .article-content :global(h2),
  .article-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.7rem;
    letter-spacing: -0.02em;
  }

  .article-content :global(h2) {
    font-size: clamp(1.28rem, 2vw, 1.6rem);
    line-height: 1.2;
    font-weight: 720;
  }

  .article-content :global(h3) {
    font-size: clamp(1.02rem, 1.4vw, 1.12rem);
    line-height: 1.3;
    font-weight: 700;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 0;
    padding-left: 1.2rem;
  }

  .article-content :global(a) {
    color: var(--accent);
  }

  .article-tags__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .article-tags__list a {
    display: inline-flex;
    align-items: center;
    min-height: 2.35rem;
    padding: 0.45rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.03);
    font-size: 0.86rem;
  }

  .article-tags__list a:hover,
  .article-pagination__link:hover {
    border-color: rgba(143, 228, 217, 0.24);
    color: var(--text);
  }

  .article-pagination {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .article-pagination__link {
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.05rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .article-pagination__link span {
    color: var(--muted);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .article-pagination__link strong {
    font-size: 0.96rem;
    line-height: 1.35;
    letter-spacing: -0.015em;
    font-weight: 700;
  }

  @media (max-width: 720px) {
    .article-page {
      padding-block: 1.85rem 3.2rem;
    }

    .article {
      gap: 1.3rem;
    }

    .article-header h1 {
      max-width: 14ch;
      font-size: clamp(1.56rem, 6.5vw, 2rem);
      line-height: 1.12;
      letter-spacing: -0.024em;
    }

    .article-content :global(h2) {
      font-size: 1.2rem;
    }

    .article-content :global(h3) {
      font-size: 1rem;
    }

    .article-pagination {
      grid-template-columns: 1fr;
    }
  }
</style>
