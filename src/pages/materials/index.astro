---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import MaterialFamilyCard from '../../components/MaterialFamilyCard.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { materialFamilies } from '../../data/materialFamilies';

const title = 'Metal Powder Materials | Titanium, Nickel, Stainless, Tool Steel and More';
const description =
  'Browse material-family pages for titanium, nickel alloy, stainless steel, tool steel, aluminum, copper, and cobalt chrome powders used in additive manufacturing.';

const posts = await getCollection('blog');
const siteUrl = Astro.site ?? new URL('https://metal3dpowder.com');

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: new URL('/materials/', siteUrl).toString(),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: siteUrl.toString(),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Materials',
        item: new URL('/materials/', siteUrl).toString(),
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Metal powder material pages',
    itemListElement: materialFamilies.map((family, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: new URL(`/materials/${family.slug}/`, siteUrl).toString(),
      name: family.label,
    })),
  },
];
---

<BaseLayout title={title} description={description} canonical="/materials/" schema={schema}>
  <SiteHeader pathname={Astro.url.pathname} />

  <main class="page-shell materials-page">
    <Breadcrumbs items={[{ href: '/', label: 'Home' }, { label: 'Materials' }]} />

    <section class="page-intro">
      <p class="eyebrow">Materials</p>
      <h1>Material-family pages built around the main alloy search intents.</h1>
      <p>
        Each family page groups related products, technical articles, and buying guidance so search traffic can land on
        a more relevant page than a generic product grid.
      </p>
    </section>

    <section class="materials-grid">
      {materialFamilies.map((family) => (
        <MaterialFamilyCard
          family={family}
          productCount={family.relatedProductIds.length}
          articleCount={posts.filter((post) => family.relatedArticleSlugs.includes(post.id)).length}
        />
      ))}
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .materials-page {
    display: grid;
    gap: 1.5rem;
    padding-block: 2rem 4rem;
  }

  .materials-grid {
    display: grid;
    gap: 1.2rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 1100px) {
    .materials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
