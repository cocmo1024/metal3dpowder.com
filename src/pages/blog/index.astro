---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { blogAuthorName, getBlogPostPath, sortBlogPosts } from '../../data/blog';
import { siteInfo } from '../../data/site';

const title = 'Metal Powder Blog | Alloy Guides, Particle Size, and AM Sourcing Articles';
const description =
  'Technical blog covering metal powder grades, particle size selection, additive manufacturing process fit, and sourcing guidance for overseas buyers.';

const formatter = new Intl.DateTimeFormat('en-US', { dateStyle: 'long' });
const posts = sortBlogPosts(await getCollection('blog'));
const featured = posts.find((post) => post.data.featured) ?? posts[0] ?? null;
const latestPosts = posts.filter((post) => post.id !== featured?.id);
const contentTracks = [
  {
    title: 'Alloy Selection',
    description: 'Compare titanium, nickel, stainless steel, copper, aluminum, and cobalt chrome powder options.',
  },
  {
    title: 'Powder Controls',
    description: 'Understand particle size, chemistry control, morphology, and handling points that matter before RFQ.',
  },
  {
    title: 'Process Fit',
    description: 'See where LPBF, EBM, and DED requirements diverge before choosing a powder specification.',
  },
];

const groupedPosts = Object.entries(
  posts.reduce<Record<string, typeof posts>>((acc, post) => {
    acc[post.data.category] ??= [];
    acc[post.data.category].push(post);
    return acc;
  }, {}),
).sort((left, right) => left[0].localeCompare(right[0]));

const slugify = (value: string) => value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const siteUrl = Astro.site ?? new URL('https://metal3dpowder.com');

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: `${siteInfo.brand} Blog`,
    description,
    url: new URL('/blog/', siteUrl).toString(),
    publisher: {
      '@type': 'Organization',
      name: siteInfo.brand,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: siteUrl.toString(),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Blog',
        item: new URL('/blog/', siteUrl).toString(),
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Metal powder technical articles',
    itemListElement: posts.map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: new URL(getBlogPostPath(post), siteUrl).toString(),
      name: post.data.title,
    })),
  },
];
---

<BaseLayout title={title} description={description} canonical="/blog/" schema={schema}>
  <SiteHeader pathname={Astro.url.pathname} />

  <main class="page-shell blog-page">
    <section class="blog-hero" aria-labelledby="blog-title">
      <div class="blog-hero__copy">
        <p class="eyebrow">Blog</p>
        <h1 id="blog-title">Metal powder articles built for alloy selection, process fit, and buying decisions.</h1>
        <p>
          Use this section to move from broad material research into specific article-level guidance on grades,
          particle size ranges, additive manufacturing fit, and quotation preparation.
        </p>
      </div>

      <div class="blog-hero__overview">
        <article>
          <span class="blog-hero__label">Editorial Scope</span>
          <strong>{posts.length} technical articles</strong>
          <p>Every article follows the same structure so buyers can compare materials and sourcing points quickly.</p>
        </article>
        <article>
          <span class="blog-hero__label">Main Topics</span>
          <strong>{groupedPosts.length} material categories</strong>
          <p>Titanium, nickel, stainless steel, aluminum, copper, and cobalt chrome content in one archive.</p>
        </article>
      </div>
    </section>

    <section class="content-tracks" aria-labelledby="content-tracks-title">
      <div class="section-heading">
        <p class="eyebrow">What You Will Find</p>
        <h2 id="content-tracks-title">A content system organized around the real buying workflow.</h2>
      </div>

      <div class="content-tracks__grid">
        {contentTracks.map((track) => (
          <article class="content-track">
            <h3>{track.title}</h3>
            <p>{track.description}</p>
          </article>
        ))}
      </div>
    </section>

    {
      featured ? (
        <section class="featured-post" aria-labelledby="featured-title">
          <div class="section-heading">
            <p class="eyebrow">Featured Guide</p>
            <h2 id="featured-title">Start with the most important article in the archive.</h2>
          </div>

          <a class="featured-post__card" href={getBlogPostPath(featured)}>
            <div class="featured-post__meta">
              <span>{featured.data.category}</span>
              <span>{formatter.format(featured.data.pubDate)}</span>
              <span>By {blogAuthorName}</span>
            </div>

            <div class="featured-post__body">
              <div class="featured-post__main">
                <h3>{featured.data.title}</h3>
                <p>{featured.data.description}</p>
              </div>

              <div class="featured-post__aside">
                <span class="featured-post__label">Article Highlights</span>
                <ul>
                  {featured.data.tags.slice(0, 4).map((tag) => <li>{tag}</li>)}
                </ul>
                <span class="featured-post__cta">Read article</span>
              </div>
            </div>
          </a>
        </section>
      ) : null
    }

    <section class="topic-directory" aria-labelledby="topic-directory-title">
      <div class="section-heading">
        <p class="eyebrow">Topics</p>
        <h2 id="topic-directory-title">Browse the archive by material family.</h2>
      </div>

      <div class="topic-directory__grid">
        {groupedPosts.map(([category, items]) => (
          <a class="topic-card" href={`#topic-${slugify(category)}`}>
            <strong>{category}</strong>
            <span>{items.length} article{items.length === 1 ? '' : 's'}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="latest-posts" aria-labelledby="latest-posts-title">
      <div class="section-heading">
        <p class="eyebrow">Latest Articles</p>
        <h2 id="latest-posts-title">Recent guides on alloy choice, powder control, and AM fit.</h2>
      </div>

      <div class="post-grid">
        {latestPosts.map((post) => (
          <article class="post-card">
            <div class="post-card__meta">
              <span>{post.data.category}</span>
              <span>{formatter.format(post.data.pubDate)}</span>
            </div>
            <h3>
              <a href={getBlogPostPath(post)}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            <div class="post-card__footer">
              <ul>
                {post.data.tags.slice(0, 3).map((tag) => <li>{tag}</li>)}
              </ul>
              <a class="post-card__link" href={getBlogPostPath(post)}>Read article</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="archive-directory" aria-labelledby="archive-directory-title">
      <div class="section-heading">
        <p class="eyebrow">Archive</p>
        <h2 id="archive-directory-title">A complete directory of every article in the blog.</h2>
      </div>

      <div class="archive-directory__groups">
        {groupedPosts.map(([category, items]) => (
          <section class="archive-group" id={`topic-${slugify(category)}`}>
            <div class="archive-group__head">
              <h3>{category}</h3>
              <span>{items.length} article{items.length === 1 ? '' : 's'}</span>
            </div>

            <div class="archive-group__list">
              {items.map((post) => (
                <article class="archive-item">
                  <div class="archive-item__meta">
                    <span>{formatter.format(post.data.pubDate)}</span>
                    <span>By {blogAuthorName}</span>
                  </div>
                  <h4>
                    <a href={getBlogPostPath(post)}>{post.data.title}</a>
                  </h4>
                  <p>{post.data.description}</p>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="blog-cta surface-card surface-card--padded" aria-labelledby="blog-cta-title">
      <div>
        <p class="eyebrow">Need A Quote</p>
        <h2 id="blog-cta-title">Move from research to a real powder inquiry.</h2>
        <p>
          When the material is narrowed down, send grade, particle size, target process, quantity, and destination
          country to the official contact channel.
        </p>
      </div>
      <a class="button button--primary" href="/Contact/">Contact Us</a>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .blog-page {
    display: grid;
    gap: 1.8rem;
    padding-block: 2.05rem 4rem;
  }

  .blog-hero,
  .content-tracks,
  .featured-post,
  .topic-directory,
  .latest-posts,
  .archive-directory {
    display: grid;
    gap: 1rem;
  }

  .blog-hero {
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.8fr);
    align-items: start;
    gap: 1.3rem;
  }

  .blog-hero__copy,
  .section-heading,
  .blog-cta > div {
    display: grid;
    gap: 0.7rem;
  }

  .blog-hero__copy {
    max-width: 46rem;
  }

  .blog-hero h1,
  .section-heading h2,
  .content-track h3,
  .featured-post__main h3,
  .post-card h3,
  .archive-group__head h3,
  .archive-item h4,
  .blog-cta h2 {
    margin: 0;
  }

  .blog-hero h1 {
    font-size: clamp(1.95rem, 4vw, 2.95rem);
    line-height: 1.08;
    letter-spacing: -0.035em;
    font-weight: 740;
  }

  .blog-hero p:last-child,
  .section-heading p:last-child,
  .content-track p,
  .featured-post__main p,
  .post-card p,
  .archive-item p,
  .blog-cta p:last-child,
  .blog-hero__overview p {
    margin: 0;
    color: var(--muted);
    line-height: 1.72;
  }

  .blog-hero__overview,
  .content-tracks__grid,
  .topic-directory__grid,
  .post-grid,
  .archive-directory__groups {
    display: grid;
    gap: 1rem;
  }

  .blog-hero__overview article,
  .content-track,
  .featured-post__card,
  .topic-card,
  .post-card,
  .archive-group {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.4rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      rgba(10, 14, 18, 0.9);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.05) inset,
      0 20px 52px rgba(0, 0, 0, 0.18);
  }

  .blog-hero__overview article,
  .content-track,
  .featured-post__card,
  .post-card,
  .archive-group {
    padding: 1.25rem;
  }

  .blog-hero__overview article {
    display: grid;
    gap: 0.45rem;
  }

  .blog-hero__label,
  .featured-post__meta,
  .post-card__meta,
  .archive-item__meta,
  .archive-group__head span,
  .topic-card span {
    color: var(--muted);
    font-size: 0.82rem;
  }

  .blog-hero__label,
  .featured-post__meta,
  .post-card__meta,
  .archive-item__meta {
    text-transform: uppercase;
    letter-spacing: 0.11em;
  }

  .blog-hero__overview strong {
    font-size: 1.16rem;
    line-height: 1.22;
    letter-spacing: -0.02em;
  }

  .section-heading {
    max-width: 42rem;
  }

  .section-heading h2,
  .blog-cta h2 {
    font-size: clamp(1.3rem, 2.3vw, 1.82rem);
    line-height: 1.16;
    letter-spacing: -0.03em;
    font-weight: 720;
  }

  .content-tracks__grid,
  .topic-directory__grid,
  .post-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .content-track {
    display: grid;
    gap: 0.6rem;
  }

  .content-track h3 {
    font-size: 1.08rem;
    line-height: 1.22;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .featured-post__card {
    display: grid;
    gap: 1rem;
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .featured-post__body {
    display: grid;
    gap: 1.15rem;
    grid-template-columns: minmax(0, 1.45fr) minmax(220px, 0.8fr);
  }

  .featured-post__main {
    display: grid;
    gap: 0.75rem;
  }

  .featured-post__main h3 {
    font-size: clamp(1.45rem, 2.65vw, 2rem);
    line-height: 1.14;
    letter-spacing: -0.03em;
    font-weight: 730;
  }

  .featured-post__aside {
    display: grid;
    gap: 0.85rem;
    padding: 1rem;
    border-radius: 1.15rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .featured-post__label {
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .featured-post__aside ul,
  .post-card ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .featured-post__aside li,
  .post-card li {
    padding: 0.4rem 0.66rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 999px;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.03);
    font-size: 0.79rem;
  }

  .featured-post__cta,
  .post-card__link {
    color: var(--accent);
    font-weight: 600;
  }

  .topic-card {
    display: grid;
    gap: 0.35rem;
    padding: 0.95rem 1rem;
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .topic-card strong {
    font-size: 1.02rem;
    line-height: 1.24;
    letter-spacing: -0.02em;
  }

  .featured-post__card:hover,
  .topic-card:hover,
  .post-card:hover {
    transform: translateY(-2px);
    border-color: rgba(143, 228, 217, 0.22);
  }

  .post-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .post-card {
    display: grid;
    gap: 0.85rem;
    align-content: start;
  }

  .post-card h3 {
    font-size: 1.12rem;
    line-height: 1.24;
    letter-spacing: -0.02em;
    font-weight: 710;
  }

  .post-card__footer {
    display: grid;
    gap: 0.8rem;
  }

  .archive-group {
    display: grid;
    gap: 1rem;
  }

  .archive-group__head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .archive-group__head h3 {
    font-size: 1.22rem;
    line-height: 1.18;
    letter-spacing: -0.02em;
    font-weight: 720;
  }

  .archive-group__list {
    display: grid;
    gap: 0.9rem;
  }

  .archive-item {
    display: grid;
    gap: 0.55rem;
    padding: 0 0 0.9rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .archive-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .archive-item h4 {
    font-size: 1rem;
    line-height: 1.3;
    letter-spacing: -0.015em;
    font-weight: 700;
  }

  .blog-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .blog-cta > div {
    max-width: 42rem;
  }

  @media (max-width: 1100px) {
    .blog-hero,
    .featured-post__body,
    .content-tracks__grid,
    .topic-directory__grid,
    .post-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .blog-page {
      gap: 1.45rem;
      padding-block: 1.85rem 3.2rem;
    }

    .blog-hero h1 {
      font-size: clamp(1.6rem, 7.2vw, 2.15rem);
      line-height: 1.1;
      letter-spacing: -0.028em;
    }

    .section-heading h2,
    .blog-cta h2 {
      font-size: 1.22rem;
      line-height: 1.18;
    }

    .featured-post__main h3 {
      font-size: clamp(1.24rem, 5.6vw, 1.58rem);
      line-height: 1.17;
    }

    .content-track h3,
    .post-card h3,
    .archive-group__head h3,
    .archive-item h4 {
      font-size: 1rem;
    }
  }
</style>
