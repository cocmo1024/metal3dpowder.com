---
import { getCollection } from 'astro:content';
import BlogArchive from '../../components/BlogArchive.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildBreadcrumbSchema, buildCollectionPageSchema } from '../../data/seo';
import { paginatePosts, POSTS_PER_PAGE, sortBlogPosts } from '../../data/blog';
import { siteInfo } from '../../data/site';

const allPosts = sortBlogPosts(await getCollection('blog'));
const { posts, totalPages } = paginatePosts(allPosts, 1, POSTS_PER_PAGE);
const siteUrl = Astro.site ?? new URL('https://metal3dpowder.com');

const title = `Metal Powder Blog | Material and Application Guides | ${siteInfo.brand}`;
const description = 'Technical blog covering metal powder materials, process fit, and real additive manufacturing applications across titanium, steel, nickel, aluminum, copper, and cobalt chrome.';
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: `${siteInfo.brand} Blog`,
    description,
    url: new URL('/blog/', siteUrl).toString(),
    publisher: {
      '@type': 'Organization',
      name: siteInfo.brand,
    },
  },
  {
    ...buildCollectionPageSchema({
      site: siteUrl,
      path: '/blog/',
      name: 'Metal powder article archive',
      description,
      items: posts.map((post) => ({
        name: post.data.title,
        path: `/posts/Alloys/${post.id}/`,
      })),
    }),
  },
  buildBreadcrumbSchema(siteUrl, [
    { name: 'Home', path: '/' },
    { name: 'Blog' },
  ]),
];
---

<BaseLayout title={title} description={description} canonical="/blog/" schema={schema}>
  <SiteHeader pathname={Astro.url.pathname} />
  <BlogArchive
    eyebrow="Blog"
    title="Technical articles on metal powder materials, process fit, and applications."
    description="A simple archive of published articles focused on alloys, process routes, and real additive manufacturing use cases."
    posts={posts}
    currentPage={1}
    totalPages={totalPages}
    pageBasePath="/blog/"
  />
  <SiteFooter />
</BaseLayout>
