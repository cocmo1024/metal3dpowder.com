---
import { getCollection } from 'astro:content';
import BlogArchive from '../../components/BlogArchive.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { paginatePosts, POSTS_PER_PAGE, sortBlogPosts } from '../../data/blog';
import { siteInfo } from '../../data/site';

const allPosts = sortBlogPosts(await getCollection('blog'));
const { posts, totalPages } = paginatePosts(allPosts, 1, POSTS_PER_PAGE);
const siteUrl = Astro.site ?? new URL('https://metal3dpowder.com');

const title = `Blog | ${siteInfo.brand}`;
const description = 'Technical articles on metal powders, additive manufacturing, and powder buying considerations.';
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: `${siteInfo.brand} Blog`,
    description,
    url: new URL('/blog/', siteUrl).toString(),
    publisher: {
      '@type': 'Organization',
      name: siteInfo.brand,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: siteUrl.toString(),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Blog',
        item: new URL('/blog/', siteUrl).toString(),
      },
    ],
  },
];
---

<BaseLayout title={title} description={description} canonical="/blog/" schema={schema}>
  <SiteHeader pathname={Astro.url.pathname} />
  <BlogArchive
    eyebrow="Blog"
    title="Technical articles on metal powder materials and buying decisions."
    description="A simple archive of all published blog articles."
    posts={posts}
    currentPage={1}
    totalPages={totalPages}
    pageBasePath="/blog/"
  />
  <SiteFooter />
</BaseLayout>
